#!/bin/sh
set -eu

if [ "${RETINUE_SKIP_GIT_HOOKS:-}" = "1" ]; then
  exit 0
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "Retinue pre-commit: pnpm is not on PATH; refusing to skip commit gate silently." >&2
  echo "Install pnpm or set RETINUE_SKIP_GIT_HOOKS=1 for an explicit bypass." >&2
  exit 1
fi

echo "Retinue pre-commit: running fast commit gate..."
pnpm run gate:commit
