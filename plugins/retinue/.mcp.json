{
  "mcpServers": {
    "retinue": {
      "command": "node",
      "args": ["./mcp-bootstrap.mjs"],
      "cwd": ".",
      "startup_timeout_sec": 30,
      "env": {
        "RETINUE_BACKEND": "opencode",
        "RETINUE_OPENCODE_AUTO_SERVE": "1",
        "RETINUE_OPENCODE_HOST": "127.0.0.1",
        "RETINUE_OPENCODE_AGENT": "explore"
      }
    }
  }
}
